<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.life-manager.daily-backup</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/md-homefolder/Desktop/multi-model-mcp/scripts/daily-backup.sh</string>
    </array>

    <!-- Prompt at noon every day. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>12</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/md-homefolder/Library/Logs/life-manager-backup-launchd.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/md-homefolder/Library/Logs/life-manager-backup-launchd.log</string>
</dict>
</plist>
